# ── Required ──
AIRLABS_API_KEY=your_airlabs_api_key     # Get one at https://airlabs.co/
MAPBOX_TOKEN=your_mapbox_token            # Get one at https://account.mapbox.com/

# ── Recommended ──
CHECKWX_API_KEY=your_checkwx_key          # Get one at https://www.checkwx.com/

# ── Optional ──
CESIUM_TOKEN=your_cesium_token            # Needed for Cesium 3D view
OPENSKY_USERNAME=your_opensky_username    # Only for ML training data
OPENSKY_PASSWORD=your_opensky_password    # Only for ML training data
